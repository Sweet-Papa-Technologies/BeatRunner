{
  "_comment": "Gate orchestration for In the Pocket. Language-agnostic + JS/TS gates on; model gates run via FoFo Judge/Reviewer subagents instead of the API-key gate scripts.",

  "policy": "policy.json",
  "fail_fast": true,

  "model": {
    "endpoint": "https://api.anthropic.com/v1/messages",
    "base_url": null,
    "model": "claude-sonnet-4-6",
    "api_key_env": "ANTHROPIC_API_KEY",
    "max_tokens": 1024,
    "timeout_seconds": 60
  },

  "gates": [
    { "name": "spec-lint",     "tier": 0, "enabled": true, "script": "spec-lint" },
    { "name": "trace-gate",    "tier": 0, "enabled": true, "script": "trace-gate" },
    { "name": "redgreen-gate", "tier": 0, "enabled": true, "script": "redgreen-gate" },
    { "name": "intent-gate",   "tier": 0, "enabled": true, "script": "intent-gate" },

    { "name": "separation-gate", "tier": 0, "enabled": false, "script": "separation-gate",
      "_note": "Procedural separation via native subagents (Judge/Reviewer). PROVENANCE.yaml documents authorship." },

    { "name": "semantic-test-judge", "tier": 1, "enabled": false, "script": "semantic-test-judge" },
    { "name": "fresh-eyes-review",   "tier": 1, "enabled": false, "script": "fresh-eyes-review",
      "_note": "Run via the fofo-reviewer subagent (Phase 5) rather than the API-key gate." }
  ]
}
