{
  "design_notes": "The chart mimics the alternating energy landscape of the synthwave track. High-energy bars use density spikes with clean 1.0-beat holds on the center lane followed by rapid outer lane taps to capture the melodic synth. To resolve previous pacing issues, the low-energy bars are aggressively thinned out to just two sparsely-spaced taps per bar, allowing the chart to breathe naturally in perfect sync with the energy curve.",
  "sections": [
    {
      "name": "Intro Peak",
      "start_bar": 0,
      "intent": "Introduce the standard speed onsets with a clean alternating layout."
    },
    {
      "name": "Main Wave",
      "start_bar": 4,
      "intent": "Densely mapped high energy bars contrasting with highly thinned low energy breathing spaces."
    },
    {
      "name": "Outro Wind Down",
      "start_bar": 10,
      "intent": "Gradually release intensity with sparse finishing taps."
    }
  ],
