      "name": "S0",
      "start_bar": 0,
      "intent": "Intro synth pads and light build-up"
    },
    {
      "name": "S1",
      "start_bar": 7,
      "intent": "Main driving synthwave drop with melodic runs"
    },
    {
      "name": "S2",
      "start_bar": 15,
      "intent": "Resolving outro with sustained synth decay"
    }
