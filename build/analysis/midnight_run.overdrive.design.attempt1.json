      "intent": "Peak drop energy with driving alternating lane sequences"
    },
    {
      "name": "S2",
      "start_bar": 7,
      "intent": "Dynamic syncopation and breathers following the melody contour"
    },
    {
      "name": "S3",
      "start_bar": 13,
      "intent": "Grand finale outro with high-density sweeps and a closing statement"
    }
  ],
