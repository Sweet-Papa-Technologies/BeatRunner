{
  "design_notes": "S0 introduces the steady synthwave pulse with alternating lane taps on the beats, accented by holds on sustain onsets to anchor the rhythmic phrase. S1 represents the peak drop where we utilize back-to-back sustains and rapid alternating 0.5-beat notes to highlight the high energy. S2 winds down the track with spaced-out taps that mirror the fading beat grid, letting the chart breathe.",
  "sections": [
    {
      "name": "Intro",
      "start_bar": 0,
      "intent": "Introduce the alternating lane flow and build anticipation with holds."
    },
    {
      "name": "Drop",
      "start_bar": 15,
      "intent": "Maximize energy with back-to-back holds and dense lane movement."
    },
    {
      "name": "Outro",
      "start_bar": 16,
      "intent": "Resolve the performance with clean, spaced-out taps."
    }
  ],
