      "name": "S0",
      "start_bar": 0,
      "intent": "Intro build-up introducing simple lane movements."
    },
    {
      "name": "S1",
      "start_bar": 2,
      "intent": "Transitionary drop with ascending lanes."
    },
    {
      "name": "S2",
      "start_bar": 3,
      "intent": "Main drop section with dynamic patterns and jack variations."
    },
    {
      "name": "S3",
      "start_bar": 11,
      "intent": "High energy synth drive with structured 4-bar variety patterns."
    },
    {
      "name": "S4",
      "start_bar": 18,
      "intent": "Outro climax resolving on steady eighth notes down to the finish."
    }
  ],
