{
  "design_notes": "We mapped the entire song, transitioning from a light synth/vocal intro with basic 'steps' into a highly active 'stream' drop in Section 1. After a brief transition buildup, the chart evolves into dense, active 'jumpstream' patterns during the primary drops (Sections 3 and 4), keeping holds aligned strictly with detected synth sustains to stay below the 12% target budget, before fading out safely with standard streams and breathing room pauses in the break/outro.",
  "phrases": [
    {
      "start_bar": 0,
      "end_bar": 10,
      "texture": "steps",
      "movement": "static",
      "crossover": "none",
      "jump_density": "none",
      "intent": "The intro: keep elements simple, focusing on core downbeats and occasional synth highlights."
    },
    {
      "start_bar": 10,
      "end_bar": 17,
      "texture": "stream",
      "movement": "zigzag",
      "crossover": "light",
      "jump_density": "accents",
      "intent": "First drop transition: continuous 8th/16th runs paired with light crossovers and jumps aligned to downbeats."
    },
    {
      "start_bar": 17,
      "end_bar": 18,
      "texture": "jacks_sparse",
      "movement": "static",
      "crossover": "none",
      "jump_density": "accents",
      "intent": "Buildup tension: brief, hard-hitting sparse jacks matching the synth sweeps."
    },
    {
      "start_bar": 18,
      "end_bar": 26,
      "texture": "jumpstream",
      "movement": "drift_L_to_R",
      "crossover": "light",
      "jump_density": "accents",
      "intent": "Melodic second drop: wide lateral flow to give players physical movement while following high melody."
    },
    {
      "start_bar": 26,
      "end_bar": 34,
      "texture": "jumpstream",
      "movement": "box",
      "crossover": "moderate",
      "jump_density": "accents",
      "intent": "Peak climax drop: heavy movement following the energy envelope with rotational flow patterns."
    },
    {
      "start_bar": 34,
      "end_bar": 38,
      "texture": "stream",
      "movement": "drift_R_to_L",
      "crossover": "light",
      "jump_density": "none",
      "intent": "Drop decay: stepping down density with smooth leftward drift patterns."
    },
    {
      "start_bar": 38,
      "end_bar": 40,
      "texture": "stops_breather",
      "movement": "static",
      "crossover": "none",
      "jump_density": "none",
      "intent": "Outro: quiet steps transitioning to a final hold mapping the decaying synthesizer release."
    }
  ],
