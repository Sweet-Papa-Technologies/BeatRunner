{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "beatforge chart critic review (Workstream D, REQ-QA-04)",
  "type": "object",
  "required": ["score", "issues"],
  "properties": {
    "score": {"type": "number", "minimum": 0, "maximum": 10},
    "verdict": {"type": "string"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["where", "problem"],
        "properties": {
          "where": {"type": "string"},
          "problem": {"type": "string"},
          "severity": {"type": "string", "enum": ["low", "medium", "high"]}
        }
      }
    }
  }
}
